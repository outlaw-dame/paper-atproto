{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "types": ["@cloudflare/workers-types"],
    "lib": ["ESNext"],
    "moduleResolution": "bundler",
    "noEmit": true
  },
  "include": ["./**/*.ts"],
  // Override parent's exclude so that the functions/ directory itself is not excluded.
  "exclude": ["../node_modules"]
}
