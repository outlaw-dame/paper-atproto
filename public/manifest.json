{
  "id": "/paper-atproto/",
  "name": "Glimpse",
  "short_name": "Glimpse",
  "description": "A Paper × Gist × Apple HIG client for ATProto",
  "start_url": "/paper-atproto/",
  "scope": "/paper-atproto/",
  "display": "standalone",
  "display_override": ["standalone", "minimal-ui"],
  "orientation": "portrait",
  "background_color": "#F2F2F7",
  "theme_color": "#F2F2F7",
  "icons": [
    {
      "src": "icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "shortcuts": [
    {
      "name": "New Post",
      "short_name": "Post",
      "description": "Compose a new post",
      "url": "/paper-atproto/?action=compose",
      "icons": [{ "src": "icon-192.png", "sizes": "192x192" }]
    },
    {
      "name": "Explore",
      "short_name": "Explore",
      "description": "Discover trending content",
      "url": "/paper-atproto/?tab=explore",
      "icons": [{ "src": "icon-192.png", "sizes": "192x192" }]
    }
  ],
  "share_target": {
    "action": "/paper-atproto/share-target",
    "method": "GET",
    "enctype": "application/x-www-form-urlencoded",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "screenshots": [
    {
      "src": "screenshots/iphone-home.png",
      "sizes": "1179x2556",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Home feed"
    },
    {
      "src": "screenshots/desktop-reader.png",
      "sizes": "2880x1800",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Desktop reader"
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "web+at",
      "url": "/paper-atproto/open?uri=%s"
    }
  ],
  "categories": ["social", "news"],
  "lang": "en",
  "prefer_related_applications": false
}
