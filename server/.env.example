NODE_ENV=development
OLLAMA_BASE_URL=http://localhost:11434
QWEN_WRITER_MODEL=qwen3:4b-instruct-2507-q4_K_M
QWEN_MULTIMODAL_MODEL=qwen3-vl:4b-instruct-q4_K_M
LLM_TIMEOUT_MS=30000
LLM_ENABLED=true
GOOGLE_FACT_CHECK_API_KEY=
GOOGLE_SAFE_BROWSING_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
# Set to true to enable Google grounding with Gemini.
VERIFY_GEMINI_GROUNDING_ENABLED=false
GEMINI_GROUNDING_MODEL=gemini-2.5-flash
# Set to true to enable Gemini-backed composer guidance.
GEMINI_COMPOSER_ENABLED=false
GEMINI_COMPOSER_MODEL=gemini-2.5-flash
GEMINI_DEEP_INTERPOLATOR_MODEL=gemini-2.5-flash
OPENAI_DEEP_INTERPOLATOR_MODEL=gpt-5.4
GOOGLE_CLOUD_PROJECT=
PREMIUM_AI_ENABLED=false
PREMIUM_AI_PROVIDER=gemini
PREMIUM_AI_DEFAULT_TIER=free
PREMIUM_AI_ALLOWLIST_DIDS=
PREMIUM_AI_TIMEOUT_MS=25000
PREMIUM_AI_RETRY_ATTEMPTS=2
VERIFY_API_ENABLED=true
VERIFY_MAX_TEXT_CHARS=1500
VERIFY_MAX_URLS=8
VERIFY_TIMEOUT_MS=12000
VERIFY_RETRY_ATTEMPTS=3
VERIFY_SHARED_SECRET=
VERIFY_ENTITY_LINKING_PROVIDER=dbpedia
VERIFY_ENTITY_LINKING_ENDPOINT=https://api.dbpedia-spotlight.org/en/annotate
VERIFY_ENTITY_LINKING_TIMEOUT_MS=5000
VERIFY_ENTITY_LINKING_API_KEY=
VERIFY_ENTITY_LINKING_DEBUG=false
PODCASTINDEX_API_KEY=
PODCASTINDEX_API_SECRET=
PODCASTINDEX_BASE_URL=https://api.podcastindex.org
PODCASTINDEX_USER_AGENT=paper-atproto/1.0 (+https://github.com/damonoutlaw/paper-atproto)
COMPRESSION_ENABLED=true
COMPRESSION_MIN_BYTES=1024
COMPRESSION_MAX_BYTES=1500000
COMPRESSION_GZIP_LEVEL=6
COMPRESSION_ZSTD_LEVEL=8
RATE_LIMIT_REDIS_URL=
RATE_LIMIT_REDIS_PREFIX=paper:ratelimit
RATE_LIMIT_REDIS_FAIL_CLOSED=false
RATE_LIMIT_TRUST_PROXY=false
RATE_LIMIT_TRUSTED_IP_HEADER=cf-connecting-ip
PORT=3011
