{
  "name": "paper-atproto",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "vite",
    "server:dev": "npm --prefix ./server run dev",
    "tunnel": "bash scripts/tunnel.sh",
    "build": "vite build",
    "server:build": "npm --prefix ./server run build",
    "start": "PORT=${PORT:-3011} npm --prefix ./server run start",
    "server:start": "npm --prefix ./server run start",
    "translation:download-models": "npm --prefix ./server run translation:download-models",
    "models:download-browser": "node scripts/download_browser_models.mjs",
    "models:download-browser:balanced": "node scripts/download_browser_models.mjs --profile balanced",
    "models:download-browser:premium": "node scripts/download_browser_models.mjs --profile premium",
    "models:export-cardiff-composer": "./.venv/bin/python scripts/export_cardiff_composer_models.py",
    "models:train-setfit-quality": "./.venv/bin/python scripts/train_export_setfit_quality.py",
    "benchmark:compression": "node scripts/benchmark_compression.mjs",
    "benchmark:hybrid-search": "node scripts/benchmark_hybrid_search.mjs",
    "eval:hard-negatives": "node scripts/eval_hard_negative_thresholds.mjs",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "typecheck:cf": "tsc --noEmit --project functions/tsconfig.json",
    "check:selector-stability": "node scripts/check_selector_stability.mjs",
    "ci:checks": "pnpm run typecheck && pnpm run check:selector-stability",
    "test": "vitest run",
    "test:search": "vitest run src/search.test.ts src/search/runtime.test.ts",
    "test:watch": "vitest",
    "deploy": "gh-pages -d dist",
    "build:cf": "VITE_DEPLOY_TARGET=cloudflare vite build",
    "deploy:cf": "pnpm run build:cf && wrangler pages deploy dist --project-name=glimpse",
    "cf:dev": "wrangler pages dev dist --compatibility-date=2025-04-01 --compatibility-flag nodejs_compat"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.32.1",
