    "@tanstack/react-query": "^5.94.5",
    "@use-gesture/react": "^10.3.1",
    "@xenova/transformers": "^2.17.2",
    "drizzle-orm": "^0.45.1",
    "feedsmith": "^2.9.1",
    "framer-motion": "^12.38.0",
    "hls.js": "^1.6.15",
    "jsonld": "^9.0.0",
    "konsta": "^5.0.8",
    "localforage": "^1.10.0",
    "lucide-react": "^0.577.0",
