    "@types/twemoji": "^13.1.2",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "drizzle-kit": "^0.31.10",
    "gh-pages": "^6.3.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "tsconfig": "^7.0.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vitest": "^4.1.2",
    "wrangler": "^4.79.0"
