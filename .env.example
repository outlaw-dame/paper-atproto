# Klipy API Key (https://partner.klipy.com/api-keys)
VITE_KLIPY_API_KEY=your_klipy_api_key_here
VITE_KLIPY_CLIENT_KEY=paper-atproto

# ATProto OAuth (browser client)
# Optional in local development. If unset, app uses loopback OAuth mode.
# For secure non-loopback origins (for example HTTPS tunnels), the app can
# derive this automatically as <origin>/oauth/client-metadata.json.
VITE_ATPROTO_OAUTH_CLIENT_ID=
VITE_ATPROTO_HANDLE_RESOLVER=https://bsky.social
# Space-delimited scopes requested during OAuth sign-in.
# Must include atproto. Include transition:generic while app scopes are transitioning.
VITE_ATPROTO_OAUTH_SCOPE=atproto transition:generic rpc:app.bsky.feed.getTimeline?aud=did:web:api.bsky.app#bsky_appview rpc:app.bsky.actor.getProfile?aud=did:web:api.bsky.app#bsky_appview
# Optional client metadata customization when served by Vite's dynamic endpoint.
VITE_ATPROTO_OAUTH_CLIENT_NAME=Glimpse
VITE_ATPROTO_OAUTH_TOS_URI=
VITE_ATPROTO_OAUTH_PRIVACY_URI=
# Optional: force metadata origin and redirect URIs (comma-separated) when
# behind reverse proxies/tunnels that need explicit values.
VITE_ATPROTO_OAUTH_METADATA_ORIGIN=
VITE_ATPROTO_OAUTH_REDIRECT_URIS=
# Optional OAuth debug logging (development only).
VITE_OAUTH_DEBUG=0

# Optional verification API integration (client -> verify-server)
VITE_GLYMPSE_VERIFY_BASE_URL=http://localhost:3001/verification
VITE_GLYMPSE_VERIFY_TIMEOUT_MS=6000
VITE_GLYMPSE_VERIFY_SHARED_SECRET=

# Optional Apple CloudKit browser integration
VITE_CLOUDKIT_CONTAINER_ID=
VITE_CLOUDKIT_API_TOKEN=
VITE_CLOUDKIT_ENVIRONMENT=production
# Optional override for the CloudKit JS loader.
# Defaults to Apple's official CDN and only same-origin or Apple-hosted HTTPS URLs are accepted.
VITE_CLOUDKIT_JS_SRC=
VITE_ENABLE_DRAFT_RECOVERY_MIRROR=false
